{
  "Anthropic": {
    "Model": "claude-sonnet-4-6"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=oncology_rag;Username=postgres;Password=postgres"
  },
  "PdfSources": [
    {
      "Url": "https://www.cancer.gov/publications/pdq/information-summaries/breast-cancer/patient-breast-treatment-pdq",
      "Name": "Breast Cancer Treatment (Patient)"
    },
    {
      "Url": "https://www.cancer.gov/publications/pdq/information-summaries/screening/patient-lung-screening-pdq",
      "Name": "Lung Cancer Screening (Patient)"
    }
  ],
  "Rag": {
    "ChunkSize": 500,
    "ChunkOverlap": 50,
    "TopK": 5,
    "SimilarityThreshold": 0.65
  },
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
